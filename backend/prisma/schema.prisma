generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  OPERATOR
  AUDITOR
}

enum ProductUnit {
  BOX
  PIECES
}

enum TransactionType {
  PURCHASE
  USAGE
  ADJUSTMENT
  TRANSFER
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String        @map("password_hash")
  role         UserRole      @default(OPERATOR)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  deletedAt    DateTime?     @map("deleted_at")
  transactions Transaction[] @relation("TransactionCreator")

  @@map("users")
}

model Product {
  id               String             @id @default(cuid())
  name             String             @unique
  unit             ProductUnit
  description      String?
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  deletedAt        DateTime?          @map("deleted_at")
  inventory        Inventory[]
  inventoryLedger  InventoryLedger[]
  transactionItems TransactionItem[]

  @@map("products")
}

model Warehouse {
  id               String             @id
  name             String
  location         String?
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  deletedAt        DateTime?          @map("deleted_at")
  inventory        Inventory[]
  inventoryLedger  InventoryLedger[]
  transactions     Transaction[]

  @@map("warehouses")
}

model Supplier {
  id           String        @id @default(cuid())
  name         String
  phone        String?
  address      String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  deletedAt    DateTime?     @map("deleted_at")
  transactions Transaction[]

  @@map("suppliers")
}

model Customer {
  id           String        @id @default(cuid())
  name         String
  phone        String?
  address      String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  deletedAt    DateTime?     @map("deleted_at")
  transactions Transaction[]

  @@map("customers")
}

model Inventory {
  id          String    @id @default(cuid())
  productId   String    @map("product_id")
  warehouseId String    @map("warehouse_id")
  quantity    Decimal   @db.Decimal(18, 3)
  updatedAt   DateTime  @updatedAt @map("updated_at")
  product     Product   @relation(fields: [productId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@map("inventory")
}

model Transaction {
  id               String             @id @default(cuid())
  type             TransactionType
  referenceNo      String             @unique @map("reference_no")
  warehouseId      String             @map("warehouse_id")
  createdBy        String             @map("created_by")
  supplierId       String?            @map("supplier_id")
  customerId       String?            @map("customer_id")
  notes            String?
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  deletedAt        DateTime?          @map("deleted_at")
  warehouse        Warehouse          @relation(fields: [warehouseId], references: [id])
  creator          User               @relation("TransactionCreator", fields: [createdBy], references: [id])
  supplier         Supplier?          @relation(fields: [supplierId], references: [id])
  customer         Customer?          @relation(fields: [customerId], references: [id])
  items            TransactionItem[]
  inventoryLedger  InventoryLedger[]
  financialLedger  FinancialLedger[]

  @@map("transactions")
}

model TransactionItem {
  id            String      @id @default(cuid())
  transactionId String      @map("transaction_id")
  productId     String      @map("product_id")
  quantity      Decimal     @db.Decimal(18, 3)
  pricePerUnit  Decimal?    @map("price_per_unit") @db.Decimal(18, 2)
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  product       Product     @relation(fields: [productId], references: [id])

  @@map("transaction_items")
}

model InventoryLedger {
  id             String      @id @default(cuid())
  productId      String      @map("product_id")
  warehouseId    String      @map("warehouse_id")
  transactionId  String      @map("transaction_id")
  changeQuantity Decimal     @map("change_quantity") @db.Decimal(18, 3)
  balanceAfter   Decimal     @map("balance_after") @db.Decimal(18, 3)
  createdAt      DateTime    @default(now()) @map("created_at")
  product        Product     @relation(fields: [productId], references: [id])
  warehouse      Warehouse   @relation(fields: [warehouseId], references: [id])
  transaction    Transaction @relation(fields: [transactionId], references: [id])

  @@map("inventory_ledger")
}

model FinancialLedger {
  id            String      @id @default(cuid())
  transactionId String      @map("transaction_id")
  debit         Decimal     @db.Decimal(18, 2)
  credit        Decimal     @db.Decimal(18, 2)
  description   String
  createdAt     DateTime    @default(now()) @map("created_at")
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@map("financial_ledger")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
